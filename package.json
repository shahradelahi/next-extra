{
  "name": "next-extra",
  "version": "0.7.0",
  "description": "next-extra offers additional methods not included in the standard Next package, such as searchParams and pathname.",
  "keywords": [
    "next",
    "nextjs",
    "react",
    "next-extra"
  ],
  "homepage": "https://github.com/shahradelahi/next-extra",
  "repository": "github:shahradelahi/next-extra",
  "license": "MIT",
  "author": "Shahrad Elahi <shahrad@litehex.com> (https://github.com/shahradelahi)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.cjs"
    },
    "./action": {
      "import": "./dist/action.js",
      "default": "./dist/action.cjs"
    },
    "./context": {
      "import": "./dist/context.js",
      "default": "./dist/context.cjs"
    },
    "./pathname": {
      "import": "./dist/pathname.js",
      "default": "./dist/pathname.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "./dist",
  "typesVersions": {
    "*": {
      "action": [
        "dist/action.d.cts",
        "dist/action.d.ts"
      ],
      "context": [
        "dist/context.d.cts",
        "dist/context.d.ts"
      ],
      "pathname": [
        "dist/pathname.d.cts",
        "dist/pathname.d.ts"
      ]
    }
  },
  "files": [
    "/dist/**/*",
    "!**/*.test.*"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "git clean -dfx \"**/node_modules/**\" dist .tsbuildinfo",
    "dev": "tsup --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm typecheck && eslint .",
    "lint:fix": "eslint --fix .",
    "prepublishOnly": "pnpm test && pnpm lint && pnpm format:check && pnpm build",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@shahrad/prettier-config",
  "dependencies": {
    "@edge-runtime/cookies": "^6.0.0",
    "@se-oss/deep-merge": "^1.1.0",
    "@se-oss/ip-address": "^1.1.0",
    "p-safe": "^1.1.0"
  },
  "devDependencies": {
    "@shahrad/eslint-config": "^1.1.0",
    "@shahrad/prettier-config": "^1.2.2",
    "@shahrad/tsconfig": "^1.2.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.10",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "next": "^16.1.6",
    "prettier": "^3.8.3",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "next": "14 || 15 || 16",
    "next-zod-action": "^1.0.0",
    "react": "18 || 19"
  },
  "peerDependenciesMeta": {
    "next-zod-action": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.34.1+sha512.b58fbde6dca66a929538021581f648b4570b6ca19b18e7cbd7f2c07a7b24454155388dacdf08f2af3678e88a6d1fe04f9d609df24bf51735a060ea041b374ab7"
}
